{
  "$schema": "https://app.kilo.ai/config.json",

  // ══════════════════════════════════════════════════════════════════════════════
  // MODEL CONFIGURATION
  // ══════════════════════════════════════════════════════════════════════════════
  "model": "kilo/nvidia/nemotron-3-super-120b-a12b:free",
  "small_model": "kilo/stepfun/step-3.7-flash:free",

  // ══════════════════════════════════════════════════════════════════════════════
  // PERMISSIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "permission": {
    "read": {
      "*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": "allow",
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "task": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    "todowrite": "allow",
    "puppeteer_navigate": "allow",
    "puppeteer_screenshot": "allow",
    "puppeteer_click": "allow",
    "puppeteer_fill": "allow",
    "puppeteer_select": "allow",
    "puppeteer_hover": "allow",
    "puppeteer_evaluate": "allow"
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // SYSTEM SETTINGS
  // ══════════════════════════════════════════════════════════════════════════════
  "compaction": {
    "auto": true,
    "prune": true
  },
  "default_agent": "master-controller",

  // ══════════════════════════════════════════════════════════════════════════════
  // INSTRUCTIONS - Global rules loaded for ALL agents and subagents
  // ══════════════════════════════════════════════════════════════════════════════
  "instructions": ["AGENTS.md", "SOUL.md", "MEMORY.md"],

  // ══════════════════════════════════════════════════════════════════════════════
  // AGENTS - PROMPT LENGKAP DI ~/.config/kilo/agent/<name>.md
  // ══════════════════════════════════════════════════════════════════════════════
  "agent": {

    // ════════════════════════════════════════════════════════════════════════════
    // PRIMARY AGENTS - Orchestration & High-level Control
    // ════════════════════════════════════════════════════════════════════════════
    "master-controller": {
      "model": "kilo/nvidia/nemotron-3-super-120b-a12b:free",
      "hidden": false,
      "description": "Master control agent for development workflow - highly obedient to rules",
      "mode": "primary",
      "color": "#10B981",
      "steps": 75,
      "name": "master-controller"
    },
    "master-controller-free": {
      "model": "kilo/nvidia/nemotron-3-super-120b-a12b:free",
      "hidden": false,
      "description": "Master control agent for development workflow - free tier version",
      "mode": "primary",
      "color": "#6B7280",
      "steps": 75,
      "name": "master-controller-free"
    },

    // ════════════════════════════════════════════════════════════════════════════
    // CORE DEVELOPMENT AGENTS - Analysis, Coding, Testing
    // ════════════════════════════════════════════════════════════════════════════
    "data-analyst": {
      "model": "kilo/deepseek/deepseek-v4-flash:discounted",
      "hidden": true,
      "description": "Synthesize structured task, explorer findings, and collector data into analysis and implementation plan",
      "mode": "subagent",
      "name": "data-analyst",
      "color": "#F59E0B"
    },
    "data-analyst-free": {
      "model": "kilo/nvidia/nemotron-3-super-120b-a12b:free",
      "hidden": true,
      "description": "Data synthesis and analysis agent",
      "mode": "subagent",
      "name": "data-analyst-free",
      "color": "#F59E0B"
    },

    "senior-code-reviewer": {
      "model": "kilo/deepseek/deepseek-v4-flash:discounted",
      "hidden": true,
      "description": "Senior code review agent - challenges executor code for duplication, maintainability, dependency impact, and reference integrity",
      "mode": "subagent",
      "name": "senior-code-reviewer",
      "color": "#8B5CF6",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "senior-code-reviewer-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Code reviewer when primary rate-limited",
      "mode": "subagent",
      "name": "senior-code-reviewer-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    "coder-execution": {
      "model": "kilo/deepseek/deepseek-v4-pro:discounted",
      "hidden": true,
      "description": "Code implementation agent with standards",
      "mode": "subagent",
      "name": "coder-execution",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "coder-execution-free": {
      "model": "kilo/nvidia/nemotron-3-ultra-550b-a55b:free",
      "hidden": true,
      "description": "Code implementation agent with standards",
      "mode": "subagent",
      "name": "coder-execution-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    "verifier": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Verification and testing agent",
      "mode": "subagent",
      "name": "verifier",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "verifier-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Verification and testing agent",
      "mode": "subagent",
      "name": "verifier-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    "security-review": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Security vulnerability scanner",
      "mode": "subagent",
      "name": "security-review",
      "color": "#EF4444",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "security-review-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Security vulnerability scanner",
      "mode": "subagent",
      "name": "security-review-free",
      "color": "#EF4444",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    "test-expert": {
      "model": "kilo/xiaomi/mimo-v2.5-pro",
      "hidden": true,
      "description": "Test generation and testing strategy expert",
      "mode": "subagent",
      "name": "test-expert",
      "color": "#F59E0B",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "test-expert-free": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Test generation and testing strategy expert",
      "mode": "subagent",
      "name": "test-expert-free",
      "color": "#F59E0B",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    // ════════════════════════════════════════════════════════════════════════════
    // INFRASTRUCTURE AGENTS - Git, Docker, Database
    // ════════════════════════════════════════════════════════════════════════════
    "git-specialist": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Specialized git operations agent",
      "mode": "subagent",
      "color": "#F97316",
      "name": "git-specialist",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "git-specialist-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Git operations when primary rate-limited",
      "mode": "subagent",
      "color": "#F97316",
      "name": "git-specialist-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9

      "hidden": true,
      "description": "Docker and container operations specialist",
      "mode": "subagent",
      "color": "#2496ED",
      "name": "docker-specialist",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "docker-specialist-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Docker operations when primary rate-limited",
      "mode": "subagent",
      "color": "#2496ED",
      "name": "docker-specialist-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    "database-specialist": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Database inspection and query analysis specialist",
      "mode": "subagent",
      "color": "#336791",
      "name": "database-specialist",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    "database-specialist-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Database operations when primary rate-limited",
      "mode": "subagent",
      "color": "#336791",
      "name": "database-specialist-free",
      "options": {
        "temperature": 0.1,
        "top_p": 0.9
      }
    },

    // ════════════════════════════════════════════════════════════════════════════
    // PM AGENTS - Project Management, Business Analysis, Requirements
    // ════════════════════════════════════════════════════════════════════════════
    "pm-controller": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": false,
      "description": "Project Manager & Business Analyst orchestration agent - for administrative and documentation workflow",
      "mode": "primary",
      "color": "#8B5CF6",
      "name": "pm-controller",
      "steps": 75      
    },
    "pm-controller-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": false,
      "description": "PM/BA orchestration agent - free tier version",
      "mode": "primary",
      "color": "#6B7280",
      "name": "pm-controller-free",
      "steps": 75
    },

    "pm-analyst": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Analyze requirements, documents, and data for PM/BA tasks",
      "mode": "subagent",
      "color": "#F59E0B",
      "name": "pm-analyst"
    },
    "pm-analyst-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: PM/BA analysis when primary rate-limited",
      "mode": "subagent",
      "color": "#EC4899",
      "name": "pm-analyst-free"
    },

    "pm-planner": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Create detailed, trackable implementation plans from specifications and analysis",
      "mode": "subagent",
      "color": "#10B981",
      "name": "pm-planner"
    },
    "pm-planner-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Project planning when primary rate-limited",
      "mode": "subagent",
      "color": "#EC4899",
      "name": "pm-planner-free"
    },

    "pm-verifier": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Verify documents, check completeness, quality, and feasibility",
      "mode": "subagent",
      "color": "#EC4899",
      "name": "pm-verifier"
    },
    "pm-verifier-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback agent for document verification when rate-limited",
      "mode": "subagent",
      "color": "#EC4899",
      "name": "pm-verifier-free"
    },

    "pm-writer": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Create documents, reports, and presentations for PM/BA tasks",
      "mode": "subagent",
      "color": "#10B981",
      "name": "pm-writer"
    },
    "pm-writer-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback agent for document creation when rate-limited",
      "mode": "subagent",
      "color": "#10B981",
      "name": "pm-writer-free"
    },

    // ════════════════════════════════════════════════════════════════════════════
    // IMAGE AGENTS - Creation, Editing, Analysis
    // ════════════════════════════════════════════════════════════════════════════
    "image-specialist": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Image creation, editing, and manipulation specialist",
      "mode": "subagent",
      "color": "#8B5CF6",
      "name": "image-specialist"
    },
    "image-specialist-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Image operations when primary rate-limited",
      "mode": "subagent",
      "color": "#8B5CF6",
      "name": "image-specialist-free"
    },

    "image-analyst": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Analyze and extract information from images",
      "mode": "subagent",
      "name": "image-analyst"
    },

    // ════════════════════════════════════════════════════════════════════════════
    // DOCUMENT AGENTS - Read, Write, Convert, Review, Analyze
    // ════════════════════════════════════════════════════════════════════════════
    "document-controller": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": false,
      "description": "Document workflow orchestrator - coordinates document review, creation, analysis and conversion",
      "mode": "primary",
      "color": "#F59E0B",
      "name": "document-controller",
      "steps": 50
    },
    "document-controller-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": false,
      "description": "Fallback: Document workflow orchestrator when primary rate-limited",
      "mode": "primary",
      "color": "#F59E0B",
      "name": "document-controller-free",
      "steps": 50
    },

    "document-reader": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Read, parse, and analyze office documents (PDF, DOCX, XLSX, PPTX)",
      "mode": "subagent",
      "color": "#EF4444",
      "name": "document-reader"
    },
    "document-reader-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Read documents when primary rate-limited",
      "mode": "subagent",
      "color": "#EF4444",
      "name": "document-reader-free"
    },

    "document-writer": {
      "model": "kilo/xiaomi/mimo-v2.5-pro",
      "hidden": true,
      "description": "Create and edit office documents (PDF, DOCX, XLSX, PPTX)",
      "mode": "subagent",
      "color": "#10B981",
      "name": "document-writer"
    },
    "document-writer-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Write documents when primary rate-limited",
      "mode": "subagent",
      "color": "#10B981",
      "name": "document-writer-free"
    },

    "document-converter": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Convert between office document formats (PDF, DOCX, XLSX, PPTX)",
      "mode": "subagent",
      "color": "#8B5CF6",
      "name": "document-converter"
    },
    "document-converter-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Convert documents when primary rate-limited",
      "mode": "subagent",
      "color": "#F59E0B",
      "name": "document-converter-free"
    },

    "document-reviewer": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Review and revise office documents (PDF, DOCX, XLSX, PPTX) - find issues and fix them directly",
      "mode": "subagent",
      "color": "#F59E0B",
      "name": "document-reviewer"
    },
    "document-reviewer-free": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Fallback: Review documents when primary rate-limited",
      "mode": "subagent",
      "color": "#F59E0B",

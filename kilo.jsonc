    // ════════════════════════════════════════════════════════════════════════════
    // DEFAULT AGENTS - Do NOT Remove
    // ════════════════════════════════════════════════════════════════════════════
    "ask": {
      "model": "kilo/kilo-auto/free"
    },
    "plan": {
      "model": "kilo/deepseek/deepseek-v4-flash:discounted"
    },
    "debug": {
      "model": "kilo/stepfun/step-3.7-flash:free"
    },
    "orchestrator": {
      "model": "kilo/deepseek/deepseek-v4-pro:discounted"
    },
    "code": {
      "model": "kilo/xiaomi/mimo-v2.5-pro"
    },
    "trading-controller": {
      "model": "kilo/nvidia/nemotron-3-ultra-550b-a55b:free",
      "description": "Primary orchestrator for trading operations - orchestrates workflow, enforces risk rules, manages user approval hooks for Bybit spot trading",
      "mode": "primary",
      "color": "#10B981",
      "steps": 100,
      "name": "trading-controller"
    },
    "trading/demo-tester-agent": {
      "model": "google/gemma-4-31b-it",
      "name": "demo-tester-agent",
      "hidden": true,
      "mode": "subagent"
    },
    "trading/portfolio-monitor-agent": {
      "model": "google/gemma-4-31b-it",
      "name": "portfolio-monitor-agent",
      "hidden": true,
      "mode": "subagent"
    },
    "trading/technical-analysis-agent": {
      "model": "google/gemma-4-31b-it",
      "name": "technical-analysis-agent",
      "hidden": true,
      "mode": "subagent"
    },
    "trade-executor-agent": {
      "description": "Order execution agent for trading system",
      "mode": "subagent",
      "hidden": true,
      "options": {
        "platform": "Bybit",
        "rest_endpoint": "https://api-demo.bybit.com",
        "ws_endpoint": "wss://stream.bybit.com/v5/private"
      },
      "name": "trade-executor-agent",
      "platform": "Bybit",
      "rest_endpoint": "https://api-demo.bybit.com",
      "ws_endpoint": "wss://stream.bybit.com/v5/private"
    },
    "signal-verification-agent": {
      "description": "Multi-signal verification - validates signals from technical analysis, market trends, and pattern detection before execution",
      "mode": "subagent",
      "hidden": true,
      "options": {
        "platform": "multi-source"
      },
      "name": "signal-verification-agent",
      "platform": "multi-source"
    },
    "signal-generator-agent": {
      "description": "Trade signal generation engine combining technical indicators into actionable buy/sell/hold signals with confidence scoring",
      "mode": "subagent",
      "hidden": true,
      "options": {
        "platform": "Bybit",
        "dependsOn": [
          "market-data-agent"
        ]
      },
      "name": "signal-generator-agent",
      "platform": "Bybit",
      "dependsOn": [
        "market-data-agent"
      ]
    },
    "RiskAssessmentAgent": {
      "description": "Intelligent risk evaluation agent for safe trading operations. Calculates position sizes, validates risk rules, monitors drawdowns, and filters trades based on volatility.",
      "mode": "subagent",
      "hidden": true,
      "options": {
        "version": "1.0.0",
        "icon": "🛡️",
        "triggers": [
          {
            "event": "signal_received"
          },
          {
            "event": "trade_validation_request"
          },
          {
            "event": "position_size_calculation"
          },
          {
            "event": "drawdown_check"
          }
        ],
        "permissions": [
          {
            "read": "portfolio"
          },
          {
            "read": "candles"
          },
          {
            "read": "signals"
          },
          {
            "write": "risk_state"
          },
          {
            "write": "validation_results"
          }
        ],
        "config_schema": {
          "max_risk_per_trade": {
            "type": "float",
            "default": 0.02,
            "description": "Maximum equity risked per trade (2%)"
          },
          "max_daily_drawdown": {
            "type": "float",
            "default": 0.05,
            "description": "Stop trading if daily drawdown exceeds this threshold (5%)"
          },
          "max_positions": {
            "type": "integer",
            "default": 5,
            "description": "Maximum concurrent open positions"
          },
          "min_reward_risk_ratio": {
            "type": "float",
            "default": 2,
            "description": "Minimum take-profit to stop-loss ratio"
          },
          "max_leverage": {
            "type": "integer",
            "default": 10,
            "description": "Maximum allowed leverage"
          },
          "min_confidence": {
            "type": "float",
            "default": 0.65,
            "description": "Minimum signal confidence threshold"
          },
          "stop_loss_atr_multiplier": {
            "type": "float",
            "default": 2,
            "description": "ATR multiplier for stop-loss calculation"
          },
          "take_profit_atr_multiplier": {
            "type": "float",
            "default": 4,
            "description": "ATR multiplier for take-profit calculation"
          },
          "max_atr_percentile": {
            "type": "integer",
            "default": 85,
            "description": "Don't trade if ATR percentile exceeds this value"
          },
          "min_volume_ratio": {
            "type": "float",
            "default": 1.2,
            "description": "Volume must exceed this multiple of average volume"
          },
          "kelly_fraction": {
            "type": "float",
            "default": 0.25,
            "description": "Kelly criterion fraction to use (0.25 = quarter Kelly)"
          },
          "position_sizing_method": {
            "type": "string",
            "default": "kelly",
            "enum": [
              "kelly",
              "fixed_fraction"
            ],
            "description": "Method for calculating position size"
          },
          "fixed_fraction_size": {
            "type": "float",
            "default": 0.1,
            "description": "Fixed fraction of equity to use if method is fixed_fraction"
          }
        }
      },
      "name": "RiskAssessmentAgent",
      "version": "1.0.0",
      "icon": "🛡️",
      "triggers": [
        {
          "event": "signal_received"
        },
        {
          "event": "trade_validation_request"
        },
        {
          "event": "position_size_calculation"
        },
        {
          "event": "drawdown_check"

    // ════════════════════════════════════════════════════════════════════════════
    // UTILITY AGENTS - Free tier, no fallback needed
    // ════════════════════════════════════════════════════════════════════════════
    "request-translator": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Translate user requests into structured tasks for master controller",
      "mode": "subagent",
      "name": "request-translator",

    },

    "document-translator": {
      "model": "kilo/kilo-auto/free",
      "hidden": true,
      "description": "Parse and structure document requests into tasks for sub-agents",
      "mode": "subagent",
      "color": "#8B5CF6",
      "name": "document-translator"
    },

    "document-analyst": {
      "model": "kilo/stepfun/step-3.7-flash:free",
      "hidden": true,
      "description": "Assess document relevance, quality, and fit for purpose",
      "mode": "subagent",
      "color": "#3B82F6",
